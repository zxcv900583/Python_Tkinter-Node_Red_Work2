    "id": "fn_s2_router",
    "type": "function",
    "z": "tab_sub2",
    "name": "路由",
    "func": "var sql=(msg.topic||'').trim().toUpperCase();\nvar op=sql.split(' ')[0];\nif(Array.isArray(msg.payload)){return [msg,null,null];}\nif(op==='INSERT'){return null;}\nif(op==='DROP'){return [{payload:[]},{payload:'RFID 資料表已刪除'},null];}\nvar m={'CREATE':'RFID 資料庫建立完成','DELETE':'RFID 資料已全部清除'};\nvar txt=m[op]||'操作完成';\nreturn [null,{payload:txt},{payload:txt}];",
    "outputs": 3,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
