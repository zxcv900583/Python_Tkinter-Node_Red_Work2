  {
    "id": "fn_s1_router",
    "type": "function",
    "z": "tab_sub1",
    "name": "路由",
    "func": "var sql=(msg.topic||'').trim().toUpperCase();\nvar op=sql.split(' ')[0];\nif(Array.isArray(msg.payload)){return [msg,null,null];}\nif(op==='INSERT'){return null;}\nif(op==='DROP'){return [{payload:[]},{payload:'LED 資料表已刪除'},null];}\nvar m={'CREATE':'LED 資料庫建立完成','DELETE':'LED 資料已全部清除'};\nvar txt=m[op]||'操作完成';\nreturn [null,{payload:txt},{payload:txt}];",
    "outputs": 3,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
