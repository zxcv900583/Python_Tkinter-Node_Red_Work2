  {
    "id": "tmpl_rfid",
    "type": "ui_template",
    "z": "tab_sub2",
    "group": "grp_s2_data",
    "name": "RFID 資料表",
    "order": 1,
    "width": "14",
    "height": 12,
    "format": "<div style=\"overflow-x:auto;padding:4px\" ng-init=\"sc='id';sd=true\">\n  <table style=\"width:100%;border-collapse:collapse;font-size:13px;\n                box-shadow:0 1px 4px rgba(0,0,0,.15)\">\n    <thead>\n      <tr style=\"background:#2E7D32;color:#fff\">\n        <th ng-click=\"sc='id';sd=!sd\"     style=\"padding:10px 14px;text-align:center;cursor:pointer;user-select:none;white-space:nowrap\">ID   <span ng-show=\"sc=='id'\"    >{{sd?'▼':'▲'}}</span></th>\n        <th ng-click=\"sc='uid';sd=!sd\"    style=\"padding:10px 14px;text-align:center;cursor:pointer;user-select:none;white-space:nowrap\">UID  <span ng-show=\"sc=='uid'\"   >{{sd?'▼':'▲'}}</span></th>\n        <th ng-click=\"sc='date';sd=!sd\"   style=\"padding:10px 14px;text-align:center;cursor:pointer;user-select:none;white-space:nowrap\">日期 <span ng-show=\"sc=='date'\"  >{{sd?'▼':'▲'}}</span></th>\n        <th ng-click=\"sc='time';sd=!sd\"   style=\"padding:10px 14px;text-align:center;cursor:pointer;user-select:none;white-space:nowrap\">時間 <span ng-show=\"sc=='time'\"  >{{sd?'▼':'▲'}}</span></th>\n        <th ng-click=\"sc='remark';sd=!sd\" style=\"padding:10px 14px;text-align:center;cursor:pointer;user-select:none;white-space:nowrap\">備註 <span ng-show=\"sc=='remark'\">{{sd?'▼':'▲'}}</span></th>\n      </tr>\n    </thead>\n    <tbody ng-if=\"msg.payload && msg.payload.length > 0\">\n      <tr ng-repeat=\"r in msg.payload | orderBy:sc:sd track by $index\"\n          ng-style=\"{background: r.remark==='異常' ? '#FFF3E0' : ($index%2===0 ? '#fafafa' : '#fff')}\">\n        <td style=\"padding:8px 14px;text-align:center;border-bottom:1px solid #e0e0e0\">{{r.id}}</td>\n        <td style=\"padding:8px 14px;text-align:center;border-bottom:1px solid #e0e0e0;font-family:monospace;font-weight:bold\">{{r.uid}}</td>\n        <td style=\"padding:8px 14px;text-align:center;border-bottom:1px solid #e0e0e0\">{{r.date}}</td>\n        <td style=\"padding:8px 14px;text-align:center;border-bottom:1px solid #e0e0e0\">{{r.time}}</td>\n        <td ng-style=\"{color: r.remark==='異常' ? '#F44336' : '#333', fontWeight: r.remark==='異常' ? 'bold' : 'normal'}\"\n            style=\"padding:8px 14px;text-align:center;border-bottom:1px solid #e0e0e0\">{{r.remark}}</td>\n      </tr>\n    </tbody>\n    <tbody ng-if=\"!msg.payload || msg.payload.length===0\">\n      <tr><td colspan=\"5\" style=\"text-align:center;padding:30px;color:#bbb;font-size:14px\">（尚無資料）</td></tr>\n    </tbody>\n  </table>\n</div>",
    "storeOutMessages": true,
    "fwdInMessages": true,
    "resendOnRefresh": true,
    "templateScope": "local",
